# GitHub Token with repo and workflow scopes
GITHUB_TOKEN=your_github_token_here

# LLM API Key (Provide at least one)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Target Repository (where the blog posts will be created)
TARGET_REPO=krkn-chaos/website

# Repositories to fetch PRs from (comma separated)
SOURCE_REPOS=krkn,krkn-hub,krknctl,krkn-operator,cerberus,krkn-ai
